# توکن ربات تلگرام (از BotFather دریافت می‌کنید) - الزامی
TELEGRAM_TOKEN=7123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# کلید API هوش مصنوعی - الزامی
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# آدرس سرور API (اگر از سایت freemodel استفاده می‌کنید همین را بگذارید، در غیر این صورت پاکش کنید)
OPENAI_BASE_URL=https://api.freemodel.dev/v1

# آیدی عددی ادمین‌ها (اگر چند ادمین دارید با کاما انگلیسی جدا کنید) - بسیار مهم!
ADMIN_IDS=123456789,987654321

# Web Admin Panel
PANEL_PASSWORD=admin123
PANEL_PORT=5000
PANEL_SECRET_KEY=change-this-to-a-random-string

# --- تنظیمات اختیاری (اگر می‌خواهید پیش‌فرض‌ها را تغییر دهید اضافه کنید) ---
# MAX_USERS=100
# RATE_LIMIT_MESSAGES=20
# RATE_LIMIT_SECONDS=60
# MAX_MESSAGE_LENGTH=4000